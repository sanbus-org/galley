#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/.."

usage() {
    cat <<'EOF'
usage: scripts/generate-parser --language <PATH> [--parser-type LL|LR] [OPTIONS]

Options are forwarded to the self-hosted Galley generator:
    --with-ast
    --no-ast
    --with-procedures
    --no-procedures
    --ast-for-terminals
    --no-ast-for-terminals
    --input-size <BITS>
EOF
}

language=""
parser_type=""
forward_args=()

while (($#)); do
    case "$1" in
        -h|--help)
            usage
            exit 0
            ;;
        --language)
            if (($# < 2)); then
                echo "error: --language requires a path" >&2
                exit 1
            fi
            language="$2"
            shift 2
            ;;
        --language=*)
            language="${1#--language=}"
            shift
            ;;
        --parser-type)
            if (($# < 2)); then
                echo "error: --parser-type requires LL or LR" >&2
                exit 1
            fi
            parser_type="$2"
            shift 2
            ;;
        --parser-type=*)
            parser_type="${1#--parser-type=}"
            shift
            ;;
        --with-ast|--no-ast|--with-procedures|--no-procedures|--ast-for-terminals|--no-ast-for-terminals)
            forward_args+=("$1")
            shift
            ;;
        --input-size)
            if (($# < 2)); then
                echo "error: --input-size requires a bit width" >&2
                exit 1
            fi
            forward_args+=("$1" "$2")
            shift 2
            ;;
        --input-size=*)
            forward_args+=("--input-size" "${1#--input-size=}")
            shift
            ;;
        --graph|--graphviz|--generate-logs|--logs-directory|--logs-directory=*)
            echo "error: $1 is not supported by the self-hosted generator" >&2
            exit 1
            ;;
        *)
            echo "error: unknown argument: $1" >&2
            exit 1
            ;;
    esac
done

if [[ -z "$language" ]]; then
    echo "error: --language is required" >&2
    exit 1
fi

if [[ -z "$parser_type" ]]; then
    if [[ -f "$language/ll.grm" ]]; then
        parser_type="LL"
    elif [[ -f "$language/lr.grm" ]]; then
        parser_type="LR"
    else
        echo "error: no ll.grm or lr.grm found in $language" >&2
        exit 1
    fi
fi

case "$parser_type" in
    LL)
        grammar_file="$language/ll.grm"
        build_target="ll-galley"
        ;;
    LR)
        grammar_file="$language/lr.grm"
        build_target="ll-galley"
        ;;
    *)
        echo "error: unsupported parser type: $parser_type" >&2
        exit 1
        ;;
esac

if [[ ! -f "$grammar_file" ]]; then
    echo "error: grammar file not found: $grammar_file" >&2
    exit 1
fi

exec zig build "$build_target" -- "$grammar_file" "${forward_args[@]}"
